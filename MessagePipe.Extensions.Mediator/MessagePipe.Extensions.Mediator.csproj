<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<LangVersion>latest</LangVersion>

	  <PackageId>MessagePipe.Extensions.Mediator</PackageId>
	  <Version>1.0.0</Version>
	  <Authors>ApiInk</Authors>
	  <Description>A high-performance, zero-allocation MediatR-style ISender wrapper for MessagePipe. Provides automatic type inference and dictionary caching for extreme CQRS performance.</Description>
	  <PackageTags>MessagePipe;CQRS;Sender;HighPerformance;ZeroAllocation;Mediator</PackageTags>
	  <PackageLicenseExpression>MIT</PackageLicenseExpression>
	  <RepositoryUrl>https://github.com/ApiInk/MessagePipe.Extensions.Mediator</RepositoryUrl>
	  <GenerateDocumentationFile>true</GenerateDocumentationFile>

	  <!-- 编译 Release 时自动生成 NuGet 包 -->
	  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MessagePipe" Version="1.8.2" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
  </ItemGroup>

</Project>
